{
  "name": "psytools",
  "version": "0.3.0",
  "description": "Zero-dependency toolkit for psychological assessments: data models, response validation, scoring, and predefined inventories (PHQ-9, GAD-7, DASS-21, WHO-5, ASRS, AQ-10) in multiple languages.",
  "keywords": [
    "psychology",
    "assessment",
    "questionnaire",
    "inventory",
    "phq-9",
    "gad-7",
    "dass-21",
    "who-5",
    "asrs",
    "aq-10",
    "adhd",
    "autism",
    "well-being",
    "mental-health",
    "therapy",
    "screening",
    "likert"
  ],
  "license": "MIT",
  "author": "Samed Kahyaoglu <samed@luckys.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/urtuba/psytools.git"
  },
  "bugs": "https://github.com/urtuba/psytools/issues",
  "homepage": "https://github.com/urtuba/psytools#readme",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "schema",
    "SOURCES.md"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && node scripts/postbuild.mjs",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "clean": "rm -rf dist",
    "test": "node --test \"test/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.esm.json --noEmit",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
